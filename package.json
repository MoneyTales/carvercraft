    "react-dom": "^19.2.0",
    "three": "^0.183.1",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "0.184.1",
